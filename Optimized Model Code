def create_interaction_features(data, max_interactions=15):
    """Create polynomial and interaction features"""

    numerical_cols = [
        'Age', 'BMI', 'Systolic_BP', 'Diastolic_BP',
        'Heart_Rate', 'Blood_Sugar', 'Cholesterol',
        'Exercise_Hours_Week', 'Hemoglobin',
        'Hospital_Visits_Year', 'Height_cm', 'Weight_kg'
    ]

    available_cols = [
        col for col in numerical_cols
        if col in data.columns
    ]

    interaction_data = data[available_cols].copy()

    interaction_data = (
        interaction_data
        .fillna(interaction_data.median())
    )

    poly = PolynomialFeatures(
        degree=2,
        interaction_only=True,
        include_bias=False
    )

    poly_features = poly.fit_transform(interaction_data)

    feature_names = poly.get_feature_names_out(
        available_cols
    )

    poly_df = pd.DataFrame(
        poly_features,
        columns=feature_names,
        index=data.index
    )

    original_features = set(available_cols)

    interaction_features = [
        col for col in poly_df.columns
        if col not in original_features
    ]

    if interaction_features:

        poly_interactions = poly_df[interaction_features]

        feature_variance = (
            poly_interactions
            .var()
            .sort_values(ascending=False)
        )

        top_interactions = (
            feature_variance
            .head(min(max_interactions,
                      len(feature_variance)))
            .index
            .tolist()
        )

        return poly_df[top_interactions]

    else:
        return pd.DataFrame(index=data.index)


