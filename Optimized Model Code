        results[name]["recall"] * weights["recall"] +
        results[name]["f1"] * weights["f1"] +
        results[name]["accuracy"] * weights["accuracy"] +
        results[name]["auc"] * weights["auc"] +
        cv_stability * weights["cv_stability"]
    )  
    # Compute weighted composite score

    ranking[name] = composite  
