# ===================== ENSURE CATEGORICAL ENCODING =====================

def ensure_categorical_encoding(data):
    """Ensure all categorical variables are properly encoded"""

    processed_data = data.copy()

    categorical_columns = [
        'Gender', 'Smoking', 'Alcohol_Consumption',
        'Diabetes', 'Hypertension',
        'Heart_Disease', 'Insurance_Type'
    ]

    for col in categorical_columns:

        if col in processed_data.columns:

            if processed_data[col].dtype == 'object':

                if col == 'Gender':
                    processed_data[col + '_encoded'] = processed_data[col].map({
                        'MALE': 1, 'FEMALE': 0,
                        'Male': 1, 'Female': 0,
                        'male': 1, 'female': 0
                    })

                elif col in [
                    'Smoking', 'Diabetes',
                    'Hypertension', 'Heart_Disease'
                ]:
                    mapping = {
                        'Yes': 1, 'No': 0,
                        'yes': 1, 'no': 0,
                        'YES': 1, 'NO': 0
                    }

                    processed_data[col + '_encoded'] = (
                        processed_data[col].map(mapping)
                    )

                elif col == 'Alcohol_Consumption':
                    mapping = {
                        'Never': 0,
                        'Occasional': 1,
                        'Frequent': 2,
                        'never': 0,
                        'occasional': 1,
                        'frequent': 2
                    }

                    processed_data[col + '_encoded'] = (
                        processed_data[col].map(mapping)
                    )

                elif col == 'Insurance_Type':
                    processed_data[col + '_encoded'] = processed_data[col].map({
                        'Public': 0,
                        'Private': 1,
                        'Uninsured': 2,
                        'government': 0,
                        'private': 1,
                        'uninsured': 2
                    })

                if col + '_encoded' in processed_data.columns:
                    processed_data[col + '_encoded'] = (
                        processed_data[col + '_encoded'].fillna(0)
                    )

    return processed_data
# ===================== CREATE ENGINEERED FEATURES =====================

def create_engineered_features(data):
    """Create new features based on domain knowledge"""

    # First ensure all categoricals are encoded
    engineered_data = ensure_categorical_encoding(data)

    # Create encoded column names if they don't exist
    encoded_cols = [
        'Gender_encoded',
        'Smoking_encoded',
        'Alcohol_Consumption_encoded',
        'Diabetes_encoded',
        'Hypertension_encoded',
        'Heart_Disease_encoded',
        'Insurance_Type_encoded'
    ]

    for col in encoded_cols:

        if col not in engineered_data.columns:

            base_col = col.replace('_encoded', '')

            if base_col in engineered_data.columns:

                if base_col == 'Gender':
                    engineered_data[col] = (
                        engineered_data[base_col]
                        .map({
                            'MALE': 1,
                            'FEMALE': 0,
                            'Male': 1,
                            'Female': 0
                        })
                        .fillna(0)
                    )

                elif base_col in [
                    'Smoking',
                    'Diabetes',
                    'Hypertension',
                    'Heart_Disease'
                ]:
                    engineered_data[col] = (
                        engineered_data[base_col]
                        .map({'Yes': 1, 'No': 0})
                        .fillna(0)
                    )

                elif base_col == 'Alcohol_Consumption':
                    engineered_data[col] = (
                        engineered_data[base_col]
                        .map({
                            'Never': 0,
                            'Occasional': 1,
                            'Frequent': 2
                        })
                        .fillna(0)
                    )

                elif base_col == 'Insurance_Type':
                    engineered_data[col] = (
                        engineered_data[base_col]
                        .map({
                            'Public': 0,
                            'Private': 1,
                            'Uninsured': 2
                        })
                        .fillna(0)
                    )

    # BMI categories
    if 'BMI' in engineered_data.columns:
        engineered_data['BMI_Category'] = pd.cut(
            engineered_data['BMI'],
            bins=[0, 18.5, 25, 30, float('inf')],
            labels=[0, 1, 2, 3]
        ).astype(int)

    # Blood pressure categories
    if all(col in engineered_data.columns
           for col in ['Systolic_BP', 'Diastolic_BP']):

        engineered_data['BP_Category'] = 0

        engineered_data.loc[
            (engineered_data['Systolic_BP'] >= 140) |
            (engineered_data['Diastolic_BP'] >= 90),
            'BP_Category'
        ] = 2

        engineered_data.loc[
            (engineered_data['Systolic_BP'].between(120, 139)) |
            (engineered_data['Diastolic_BP'].between(80, 89)),
            'BP_Category'
        ] = 1

    # Age groups
    if 'Age' in engineered_data.columns:
        engineered_data['Age_Group'] = pd.cut(
            engineered_data['Age'],
            bins=[0, 30, 50, 65, float('inf')],
            labels=[0, 1, 2, 3]
        ).astype(int)

    # Health risk combinations
    if all(col in engineered_data.columns
           for col in ['Diabetes_encoded', 'Hypertension_encoded']):

        engineered_data['Diabetes_Hypertension'] = (
            engineered_data['Diabetes_encoded'] &
            engineered_data['Hypertension_encoded']
        ).astype(int)

    if all(col in engineered_data.columns
           for col in ['Smoking_encoded',
                       'Alcohol_Consumption_encoded']):

        engineered_data['Smoking_Alcohol'] = (
            (engineered_data['Smoking_encoded'] > 0) &
            (engineered_data['Alcohol_Consumption_encoded'] > 0)
        ).astype(int)

    # Cardiovascular risk factors count
    cv_risk_factors = [
        'Smoking_encoded',
        'Diabetes_encoded',
        'Hypertension_encoded',
        'Heart_Disease_encoded'
    ]

    available_cv_factors = [
        col for col in cv_risk_factors
        if col in engineered_data.columns
    ]

    if available_cv_factors:
        engineered_data['CV_Risk_Count'] = (
            engineered_data[available_cv_factors]
            .sum(axis=1)
        )

    # Metabolic indicators
    metabolic_cols = ['BMI', 'Blood_Sugar', 'Cholesterol']

    if all(col in engineered_data.columns
           for col in metabolic_cols):

        engineered_data['Metabolic_Score'] = (
            engineered_data['BMI'] * 0.3 +
            engineered_data['Blood_Sugar'] * 0.4 +
            engineered_data['Cholesterol'] * 0.3
        ) / 100

    # Physical activity vs BMI ratio
    if all(col in engineered_data.columns
           for col in ['Exercise_Hours_Week', 'BMI']):

        engineered_data['Exercise_BMI_Ratio'] = (
            engineered_data['Exercise_Hours_Week'] /
            (engineered_data['BMI'] + 1)
        )

    # Healthcare utilization intensity
    if all(col in engineered_data.columns
           for col in ['Hospital_Visits_Year',
                       'CV_Risk_Count']):

        engineered_data['Healthcare_Intensity'] = (
            engineered_data['Hospital_Visits_Year'] *
            engineered_data['CV_Risk_Count']
        )

    # Vital signs composite
    vital_cols = [
        'Heart_Rate',
        'Systolic_BP',
        'Temperature_F'
    ]

    if all(col in engineered_data.columns
           for col in vital_cols):

        engineered_data['Vital_Signs_Composite'] = (
            (engineered_data['Heart_Rate'] - 70) / 12 +
            (engineered_data['Systolic_BP'] - 120) / 20 +
            (engineered_data['Temperature_F'] - 98.6) / 1.5
        ) / 3

    # Original engineered features
    engineered_data['BMI_Age_Interaction'] = (
        engineered_data['BMI'] *
        engineered_data['Age']
    )

    engineered_data['BP_Ratio'] = (
        engineered_data['Systolic_BP'] /
        engineered_data['Diastolic_BP'].replace(0, np.nan)
    )

    engineered_data['BP_Ratio'] = (
        engineered_data['BP_Ratio']
        .fillna(engineered_data['BP_Ratio'].median())
    )

    engineered_data['High_Cholesterol'] = (
        engineered_data['Cholesterol'] >
        engineered_data['Cholesterol'].median()
    ).astype(int)

    engineered_data['High_Blood_Sugar'] = (
        engineered_data['Blood_Sugar'] >
        engineered_data['Blood_Sugar'].median()
    ).astype(int)

    engineered_data['Low_Exercise'] = (
        engineered_data['Exercise_Hours_Week'] <
        engineered_data['Exercise_Hours_Week'].median()
    ).astype(int)

    engineered_data['Health_Score'] = (
        (engineered_data['Exercise_Hours_Week'] /
         engineered_data['Exercise_Hours_Week'].max()) * 0.3 +
        (1 - engineered_data['BMI'] /
         engineered_data['BMI'].max()) * 0.3 +
        (1 - engineered_data['Cholesterol'] /
         engineered_data['Cholesterol'].max()) * 0.2 +
        (1 - engineered_data['Blood_Sugar'] /
         engineered_data['Blood_Sugar'].max()) * 0.2
    )

    return engineered_data


