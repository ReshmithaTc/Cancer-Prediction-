def perform_feature_selection(X, y, n_features=20):
    """Perform multiple feature selection techniques"""

    print("\n" + "="*50)
    print("FEATURE SELECTION")
    print("="*50)

    selection_results = {}

    # 1. Univariate feature selection
    selector_univariate = SelectKBest(
        score_func=f_classif,
        k=min(n_features, X.shape[1])
    )

    X_univariate = selector_univariate.fit_transform(X, y)

    univariate_features = (
        X.columns[selector_univariate.get_support()]
        .tolist()
    )

    univariate_scores = (
        selector_univariate.scores_[
            selector_univariate.get_support()
        ]
    )

    selection_results['univariate'] = {
        'features': univariate_features,
        'scores': univariate_scores,
        'X_selected': pd.DataFrame(
            X_univariate,
            columns=univariate_features,
            index=X.index
        )
    }

    # 2. Recursive Feature Elimination
    rf_selector = RandomForestClassifier(
        n_estimators=100,
        random_state=42,
        n_jobs=-1
    )

    rfe = RFE(
        estimator=rf_selector,
        n_features_to_select=min(n_features, X.shape[1]),
        step=1
    )

    X_rfe = rfe.fit_transform(X, y)

    rfe_features = X.columns[rfe.support_].tolist()

    selection_results['rfe'] = {
        'features': rfe_features,
        'X_selected': pd.DataFrame(
            X_rfe,
            columns=rfe_features,
            index=X.index
        )
    }

    # 3. Random Forest Importance
    rf_importance = RandomForestClassifier(
        n_estimators=100,
        random_state=42,
        n_jobs=-1
    )

    rf_importance.fit(X, y)

    feature_importance = pd.DataFrame({
        'feature': X.columns,
        'importance': rf_importance.feature_importances_
    }).sort_values('importance', ascending=False)

    top_rf_features = (
        feature_importance
        .head(min(n_features, X.shape[1]))
        ['feature']
        .tolist()
    )

    selection_results['rf_importance'] = {
        'features': top_rf_features,
        'importance': feature_importance.head(
            min(n_features, X.shape[1])
        )['importance'].tolist(),
        'X_selected': X[top_rf_features]
    }

    return selection_results, feature_importance


def evaluate_feature_combinations(selection_results, y):
    """Evaluate different feature selection combinations"""

    print("\nEvaluating feature selection methods:")

    evaluation_results = {}

    for method, results_dict in selection_results.items():

        X_selected = results_dict['X_selected']

        rf_model = RandomForestClassifier(
            n_estimators=100,
            random_state=42,
            n_jobs=-1
        )

        cv_scores = cross_val_score(
            rf_model,
            X_selected,
            y,
            cv=5,
            scoring='recall'
        )

        evaluation_results[method] = {
            'cv_mean': cv_scores.mean(),
            'cv_std': cv_scores.std(),
            'features': results_dict['features'],
            'n_features': len(results_dict['features'])
        }

        print(f"{method.upper()} - Recall: "
              f"{cv_scores.mean():.4f} "
              f"(+/- {cv_scores.std()*2:.4f})")

    return evaluation_results


